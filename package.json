{
  "name": "splatt",
  "version": "1.0.0",
  "type": "module",
  "description": "Splatt - IR Target Shooting Training System",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
